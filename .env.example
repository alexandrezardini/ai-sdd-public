# Backend Environment Variables

# JWT Configuration
APP_JWT_SECRET=your-256-bit-secret-key-here-minimum-32-chars-required
APP_JWT_ISSUER=video-max

# Database (dev uses docker-compose defaults)
DB_URL=jdbc:postgresql://localhost:5432/video_max_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Mail Configuration (dev uses MailHog)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
APP_MAIL_RESET_LINK_BASE=http://localhost:3000/reset-password

# Rate Limiting
APP_RATE_LIMIT_TRUST_PROXY=false

# Frontend Environment Variables

# API Base URL
NEXT_PUBLIC_API_BASE=http://localhost:8080/api/v1
